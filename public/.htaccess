<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # API Rewrites
  RewriteRule ^api/steadfast$ api/steadfast.php [L]
  RewriteRule ^api/client-meta$ api/client-meta.php [L]

  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l
  RewriteRule . /index.html [L]
</IfModule>
